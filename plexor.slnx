<Solution>

  <!-- ====================================================================== -->
  <!-- Plexor Cloud Platform — solution file (.slnx, .NET 9+ format)        -->
  <!--                                                                        -->
  <!-- Conventions:                                                            -->
  <!--   /src/                — production code                                 -->
  <!--   /src/build/          — MSBuild SDK / shared targets (FIRST:           -->
  <!--                          topological order so VerifyFormatOnBuild       -->
  <!--                          fires exactly once per solution build)         -->
  <!--   /src/shared/         — kernel + cross-cutting libraries                -->
  <!--   /src/modules/<M>/     — vertical-slice modules (Domain/Application/    -->
  <!--                           Infrastructure)                                 -->
  <!--   /src/host/           — host process (Plexor.Host) + NodeAgent + Migrator-->
  <!--   /src/installer/      — NativeAOT CLI installer                          -->
  <!--   /src/providers/      — pluggable provider plugins                       -->
  <!--   /tests/              — unit / integration / architecture / benchmarks   -->
  <!--   /deploy/             — helm / terraform / ansible / docker / iso        -->
  <!--   /contracts/          — OpenAPI specs and integration contracts          -->
  <!--   /samples/            — example plexor.yaml cluster specs                -->
  <!--   /tools/              — codegen, scaffolds, dev CLI                      -->
  <!--   /web/                — frontend (pnpm + Turbo monorepo)                 -->
  <!--   /agents/docs/        — intent docs, architecture, ops                   -->
  <!-- ====================================================================== -->

  <Folder Name="/src/" />

  <!-- ============ Build SDK (top of topo order — fires gates once) ====== -->
  <Folder Name="/src/build/">
    <Project Path="src/build/Plexor.Build.Tools/Plexor.Build.Tools.csproj" />
  </Folder>

  <!-- ============ Shared libraries (kernel + cross-cutting) ============== -->
  <Folder Name="/src/shared/">
    <Project Path="src/shared/Plexor.Shared.Kernel/Plexor.Shared.Kernel.csproj" />
    <Project Path="src/shared/Plexor.Shared.Contracts/Plexor.Shared.Contracts.csproj" />
    <Project Path="src/shared/Plexor.Shared.Persistence/Plexor.Shared.Persistence.csproj" />
    <Project Path="src/shared/Plexor.Shared.Telemetry/Plexor.Shared.Telemetry.csproj" />
    <Project Path="src/shared/Plexor.Shared.Http/Plexor.Shared.Http.csproj" />
    <Project Path="src/shared/Plexor.Shared.Composition/Plexor.Shared.Composition.csproj" />
  </Folder>

  <!-- ============ Modules (Domain / Application / Infrastructure) ========== -->
  <Folder Name="/src/modules/">

    <Folder Name="/src/modules/Plexor.Modules.Compute/">
      <Project Path="src/modules/Plexor.Modules.Compute/Plexor.Modules.Compute.Domain/Plexor.Modules.Compute.Domain.csproj" />
      <Project Path="src/modules/Plexor.Modules.Compute/Plexor.Modules.Compute.Application/Plexor.Modules.Compute.Application.csproj" />
      <Project Path="src/modules/Plexor.Modules.Compute/Plexor.Modules.Compute.Infrastructure/Plexor.Modules.Compute.Infrastructure.csproj" />
    </Folder>

    <Folder Name="/src/modules/Plexor.Modules.Network/">
      <Project Path="src/modules/Plexor.Modules.Network/Plexor.Modules.Network.Domain/Plexor.Modules.Network.Domain.csproj" />
      <Project Path="src/modules/Plexor.Modules.Network/Plexor.Modules.Network.Application/Plexor.Modules.Network.Application.csproj" />
      <Project Path="src/modules/Plexor.Modules.Network/Plexor.Modules.Network.Infrastructure/Plexor.Modules.Network.Infrastructure.csproj" />
    </Folder>

    <Folder Name="/src/modules/Plexor.Modules.Storage/">
      <Project Path="src/modules/Plexor.Modules.Storage/Plexor.Modules.Storage.Domain/Plexor.Modules.Storage.Domain.csproj" />
      <Project Path="src/modules/Plexor.Modules.Storage/Plexor.Modules.Storage.Application/Plexor.Modules.Storage.Application.csproj" />
      <Project Path="src/modules/Plexor.Modules.Storage/Plexor.Modules.Storage.Infrastructure/Plexor.Modules.Storage.Infrastructure.csproj" />
    </Folder>

    <Folder Name="/src/modules/Plexor.Modules.Identity/">
      <Project Path="src/modules/Plexor.Modules.Identity/Plexor.Modules.Identity.Domain/Plexor.Modules.Identity.Domain.csproj" />
      <Project Path="src/modules/Plexor.Modules.Identity/Plexor.Modules.Identity.Application/Plexor.Modules.Identity.Application.csproj" />
      <Project Path="src/modules/Plexor.Modules.Identity/Plexor.Modules.Identity.Infrastructure/Plexor.Modules.Identity.Infrastructure.csproj" />
    </Folder>

    <Folder Name="/src/modules/Plexor.Modules.Tenants/">
      <Project Path="src/modules/Plexor.Modules.Tenants/Plexor.Modules.Tenants.Domain/Plexor.Modules.Tenants.Domain.csproj" />
      <Project Path="src/modules/Plexor.Modules.Tenants/Plexor.Modules.Tenants.Application/Plexor.Modules.Tenants.Application.csproj" />
      <Project Path="src/modules/Plexor.Modules.Tenants/Plexor.Modules.Tenants.Infrastructure/Plexor.Modules.Tenants.Infrastructure.csproj" />
    </Folder>

    <Folder Name="/src/modules/Plexor.Modules.Billing/">
      <Project Path="src/modules/Plexor.Modules.Billing/Plexor.Modules.Billing.Domain/Plexor.Modules.Billing.Domain.csproj" />
      <Project Path="src/modules/Plexor.Modules.Billing/Plexor.Modules.Billing.Application/Plexor.Modules.Billing.Application.csproj" />
      <Project Path="src/modules/Plexor.Modules.Billing/Plexor.Modules.Billing.Infrastructure/Plexor.Modules.Billing.Infrastructure.csproj" />
    </Folder>

    <Folder Name="/src/modules/Plexor.Modules.Telemetry/">
      <Project Path="src/modules/Plexor.Modules.Telemetry/Plexor.Modules.Telemetry.Application/Plexor.Modules.Telemetry.Application.csproj" />
      <Project Path="src/modules/Plexor.Modules.Telemetry/Plexor.Modules.Telemetry.Infrastructure/Plexor.Modules.Telemetry.Infrastructure.csproj" />
    </Folder>

  </Folder>

  <!-- ============ Hosts (entry points) =================================== -->
  <Folder Name="/src/host/">
    <Project Path="src/host/Plexor.Host/Plexor.Host.csproj" />
    <Project Path="src/host/Plexor.Migrator/Plexor.Migrator.csproj" />
    <Project Path="src/host/Plexor.NodeAgent/Plexor.NodeAgent.csproj" />
  </Folder>

  <!-- ============ Installer (NativeAOT CLI) ============================= -->
  <Folder Name="/src/installer/">
    <Project Path="src/installer/Plexor.Installer.Cli/Plexor.Installer.Cli.csproj" />
  </Folder>

  <!-- ============ Provider plugins ======================================= -->
  <Folder Name="/src/providers/">
    <Project Path="src/providers/Plexor.Core.Providers/Plexor.Core.Providers.csproj" />
    <Project Path="src/providers/Plexor.Providers.Compute.Kvm/Plexor.Providers.Compute.Kvm.csproj" />
    <Project Path="src/providers/Plexor.Providers.Storage.MinIo/Plexor.Providers.Storage.MinIo.csproj" />
    <Project Path="src/providers/Plexor.Providers.Network.Ovs/Plexor.Providers.Network.Ovs.csproj" />
    <Project Path="src/providers/Plexor.Providers.Os.Ubuntu/Plexor.Providers.Os.Ubuntu.csproj" />
    <Project Path="src/providers/Plexor.Providers.Orchestrator.K3s/Plexor.Providers.Orchestrator.K3s.csproj" />
  </Folder>

  <!-- ============ Tests =================================================== -->
  <Folder Name="/tests/" />
  <Folder Name="/tests/unit/">
    <Project Path="tests/unit/Plexor.ArchitectureTests/Plexor.ArchitectureTests.csproj" />
    <Project Path="tests/unit/Plexor.Modules.Compute.Unit/Plexor.Modules.Compute.Unit.csproj" />
    <Project Path="tests/unit/Plexor.Modules.Network.Unit/Plexor.Modules.Network.Unit.csproj" />
    <Project Path="tests/unit/Plexor.Modules.Storage.Unit/Plexor.Modules.Storage.Unit.csproj" />
    <Project Path="tests/unit/Plexor.Modules.Identity.Unit/Plexor.Modules.Identity.Unit.csproj" />
    <Project Path="tests/unit/Plexor.Modules.Tenants.Unit/Plexor.Modules.Tenants.Unit.csproj" />
    <Project Path="tests/unit/Plexor.Modules.Billing.Unit/Plexor.Modules.Billing.Unit.csproj" />
  </Folder>
  <Folder Name="/tests/integration/">
    <Project Path="tests/integration/Plexor.Installer.Tests/Plexor.Installer.Tests.csproj" />
    <Project Path="tests/integration/Plexor.Api.IntegrationTests/Plexor.Api.IntegrationTests.csproj" />
  </Folder>
  <Folder Name="/tests/benchmarks/">
    <Project Path="tests/benchmarks/Plexor.Bench/Plexor.Bench.csproj" />
  </Folder>

</Solution>