{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "paths": {
      "@plexor/ui": ["./shared/ui/src/index.ts"],
      "@plexor/ui/*": ["./shared/ui/src/*"],
      "@plexor/lib": ["./shared/lib/src/index.ts"],
      "@plexor/lib/*": ["./shared/lib/src/*"],
      "@plexor/api": ["./shared/api/src/index.ts"],
      "@plexor/api/*": ["./shared/api/src/*"]
    }
  },
  "exclude": ["node_modules", "**/dist", "**/.turbo", "**/coverage"]
}
