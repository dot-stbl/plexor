<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <!--
    Conventions per the reference project's testing rules:

      - xUnit for test runner
      - Shouldly for assertions (NOT FluentAssertions — Shouldly has the
        better dotnet ecosystem fit and reads more naturally)
      - NSubstitute for mocking (NOT Moq)
      - Bogus for fake data generation
      - Testcontainers for integration tests with real PostgreSQL/Redis
      - Respawn to reset DB state between tests
      - NetArchTest.Rules for architectural boundary tests

    Every test class is `sealed`. Tests follow AAA pattern. Test naming:
      `Method_Scenario_ExpectedResult`
  -->

  <ItemGroup>
    <PackageReference Include="Bogus" Version="35.6.1" />
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="NSubstitute" Version="5.3.0" />
    <PackageReference Include="Respawn" Version="6.2.1" />
    <PackageReference Include="Shouldly" Version="4.3.0" />
    <PackageReference Include="Testcontainers.PostgreSql" Version="4.8.0" />
    <PackageReference Include="Testcontainers.Redis" Version="4.8.0" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageReference Include="JunitXml.TestLogger" Version="6.1.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\modules\Plexor.Modules.Compute\Plexor.Modules.Compute.Domain\Plexor.Modules.Compute.Domain.csproj" />
    <ProjectReference Include="..\..\..\src\modules\Plexor.Modules.Compute\Plexor.Modules.Compute.Application\Plexor.Modules.Compute.Application.csproj" />
    <ProjectReference Include="..\..\..\src\modules\Plexor.Modules.Compute\Plexor.Modules.Compute.Infrastructure\Plexor.Modules.Compute.Infrastructure.csproj" />
    <ProjectReference Include="..\..\..\src\shared\Plexor.Shared.Kernel\Plexor.Shared.Kernel.csproj" />
    <ProjectReference Include="..\..\..\src\shared\Plexor.Shared.Persistence\Plexor.Shared.Persistence.csproj" />
  </ItemGroup>

</Project>