<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <!-- The library under test -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <ProjectReference Include="..\..\..\src\shared\Plexor.Shared.Filtering\Plexor.Shared.Filtering.csproj" />

    <!-- EF Core InMemory for ApplyFilter / ApplySort tests in Persistence/ -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="10.0.9" />
  </ItemGroup>

  <ItemGroup>
    <!-- xUnit + Shouldly per testing-stack-and-pyramid.md. -->
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageReference Include="Shouldly" Version="4.3.0" />
    <!--
      NSubstitute / Moq deliberately omitted. Both pull Castle.Core
      whose lowest published target is net6.0; the .NET 10 testhost
      refuses to load that path (deps.json says lib/net6.0 but the
      host wants lib/net10.0). When the FilterableSchemaFilter tests
      in Schema/ need mocks, add NSubstitute 6.x once it ships a
      net10-compatible Castle.Core dependency. Until then, the tests
      here are pure assertions on parser output.
    -->
  </ItemGroup>

  <!--
    xUnit tests legitimately index tokens by position (tokens[i]). CA1826
    wants direct indexer; we keep the explicit indexing for readability.
    CS1591 wants XML doc on every public method — test method names are
    self-documenting via [Fact(DisplayName = "...")], so we suppress it.
  -->
  <PropertyGroup>
    <NoWarn>$(NoWarn);CA1826;CS1591</NoWarn>
  </PropertyGroup>

</Project>
