<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <RootNamespace>Plexor.Modules.Audit.Domain</RootNamespace>
    <AssemblyName>Plexor.Modules.Audit.Domain</AssemblyName>
  </PropertyGroup>

  <!--
    Plexor.Modules.Audit.Domain — pure C# domain model for the Audit module.
    Holds the audit-event aggregates, query value objects, and event metadata.
    No infrastructure dependencies (EF Core, ASP.NET, JSON) live here.
  -->

  <ItemGroup>
    <ProjectReference Include="..\..\..\shared\Plexor.Shared.Kernel\Plexor.Shared.Kernel.csproj" />
    <ProjectReference Include="..\..\..\shared\Plexor.Shared.Contracts\Plexor.Shared.Contracts.csproj" />
  </ItemGroup>

</Project>
