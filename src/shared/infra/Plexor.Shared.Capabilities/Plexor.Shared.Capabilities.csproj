<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <!--
    Plexor.Shared.Capabilities — structured capability record + NodeProbe
    detection logic. Lives in infra/ (cross-cutting shared kernel)
    because both NodeAgent (probe + send) and Plexor.Host
    (persist + scheduler) need it.

    Replaces the legacy NodeSpec.Providers[] (string[]) with a
    structured NodeCapabilities record. The probe is the only
    source of truth for what a node can do; operator-overridden
    `node.yaml.capabilities` is supported as a fallback for
    when the probe can't see through (containers, restricted mounts).
  -->

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.0" />
    <PackageReference Include="System.Text.Json" Version="10.0.0" />
  </ItemGroup>

</Project>