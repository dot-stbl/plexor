# =====================================================================
# .editorconfig — C# / .NET Coding Rules
# Companion to .agents/rules/coding/CODING-RULES.md
# =====================================================================
# Severity legend (effective enforcement in this repo):
#   error / warning — build FAILS. `warning` is promoted to error by
#                     <TreatWarningsAsErrors>true</> in Directory.Build.props,
#                     so for analyzer rules `warning` == `error` at build time.
#   suggestion / hidden — NOT a compiler error, but the VerifyFormatOnBuild
#                     target runs `dotnet format --verify` on every solution
#                     build and FAILS it on any auto-fixable drift (escape:
#                     -p:DisableFormatOnBuild=true). So these are enforced too.
#   silent / none   — not enforced anywhere (IDE-only / off).
#
# Required analyzers (centralized in Directory.Packages.props + .csproj):
#   Microsoft.CodeAnalysis.NetAnalyzers          (CA rules)
#   Microsoft.VisualStudio.Threading.Analyzers   (VSTHRD rules)
#   Meziantou.Analyzer                           (MA rules)
#   Roslynator.Analyzers                         (RCS rules)
#   Roslynator.Formatting.Analyzers               (layout rules)
#   Roslynator.CodeAnalysis.Analyzers             (analysis rules)
#
# Cross-platform note:
#   end_of_line = lf для всего репозитория.
#   Windows-разработчики должны иметь .gitattributes в корне:
#       * text=auto eol=lf
#   и `git config --global core.autocrlf input`.
#
# Build integration:
#   - src/build/Hybrid.Build.Tools defines the VerifyFormatOnBuild target
#     (runs once per solution build, before any project compiles). It runs
#     `dotnet format --verify-no-changes --severity hidden` and FAILS the
#     build on drift. So `dotnet build console.x.slnx` IS the single
#     verification command — compile + analyzers + format, one gate,
#     identical to CI. Escapes (inner-loop only):
#         dotnet build -p:DisableFormatOnBuild=true        # skip the gate
#         dotnet build -p:FormatOnBuildTreatAsWarning=true # warn, don't fail
#     Fix drift: dotnet format console.x.slnx
#   - Directory.Build.props sets:
#         <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
#         <AnalysisLevel>latest</AnalysisLevel>
#
# Suppression policy:
#   - severity = none rules are documented inline (with reason + project
#     context). They do NOT appear in build log.
#   - Adding a new severity = none requires owner approval per
#     .agents/rules/coding/ANALYZERS.md.
#   - To see all rules (including none) in your local build, query
#     `dotnet format --severity info --verify-no-changes` or use IDE.
# =====================================================================

root = true

# ---------------------------------------------------------------------
# Base — все файлы
# ---------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,yml,yaml,xml,csproj,props,targets}]
indent_size = 2

[{*.yaml,*.yml}]
indent_size = 2

[{*.bash,*.sh,*.zsh}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# =====================================================================
# C# rules — main block
# =====================================================================
[*.cs]

#---------------------------------------------------------------------
# Indentation
#---------------------------------------------------------------------
csharp_indent_case_contents = true
csharp_indent_switch_labels = true

#---------------------------------------------------------------------
# Using directives — System.* первым
#---------------------------------------------------------------------
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace : error

#---------------------------------------------------------------------
# Section 7: var — всегда, когда тип очевиден (ERROR)
#---------------------------------------------------------------------
csharp_style_var_for_built_in_types = true : error
csharp_style_var_when_type_is_apparent = true : error
csharp_style_var_elsewhere = true : error
dotnet_diagnostic.IDE0007.severity = error # use var
dotnet_diagnostic.IDE0008.severity = none # use explicit type — inverse of IDE0007
dotnet_diagnostic.IDE0046.severity = none # convert to conditional expression — owner-disabled: цепочки if (typeof(T)==typeof(long)) ... else if ... лучше читаются чем nested ternary (RCS1238 конфликтует). Format не трогает if-структуру.
dotnet_diagnostic.IDE0072.severity = none # populate switch expression — owner-disabled: auto-format разворачивает wildcard `_ =>` на per-kind case'ы с NotImplementedException (триггерит MA0025). Wildcard preferred — JsonElement.ValueKind cases handled explicitly.
dotnet_diagnostic.IDE0010.severity = none # populate switch statement — owner-disabled: same family as IDE0072, auto-format adds exhaustive cases that conflict with wildcard `_ =>`.
dotnet_diagnostic.CMK0001.severity = warning # AccessFilter missing on public controller action — Phase 18 fail-closed authorization.
dotnet_diagnostic.IDE1006.severity = none # naming style — owner-disabled: статические readonly массивы типа `helpFlags` (camelCase) конфликтуют с дефолтом PascalCase для публичных. Per-glob Migrations-override уже есть; здесь глобально выключаем чтобы `private static readonly string[]` с lowerCamel не ломал билд.
dotnet_diagnostic.IDE0290.severity = warning # use primary constructor — codestyle-pref

#---------------------------------------------------------------------
# Section 8: File-scoped namespaces — обязательно
#---------------------------------------------------------------------
csharp_style_namespace_declarations = file_scoped : error
dotnet_diagnostic.IDE0161.severity = error

#---------------------------------------------------------------------
# Section 9: Braces — всегда и везде (ERROR)
#---------------------------------------------------------------------
csharp_prefer_braces = true : error
dotnet_diagnostic.IDE0011.severity = error

#---------------------------------------------------------------------
# Section 5: Pattern matching & minimal code
#---------------------------------------------------------------------
csharp_style_pattern_matching_over_is_with_cast_check = true : error
csharp_style_pattern_matching_over_as_with_null_check = true : error
csharp_style_prefer_switch_expression = true : warning
csharp_style_prefer_pattern_matching = true : warning
csharp_style_prefer_not_pattern = true : warning
csharp_style_prefer_extended_property_pattern = true : warning

# Conditional expressions (ternary)
dotnet_style_prefer_conditional_expression_over_assignment = true : warning
dotnet_style_prefer_conditional_expression_over_return = true : warning

# Inline variable declarations
csharp_style_inlined_variable_declaration = true : error

# Использовать pattern matching вместо null-check
dotnet_diagnostic.IDE0078.severity = warning
dotnet_diagnostic.IDE0083.severity = warning

#---------------------------------------------------------------------
# Section 6: Async / await
#---------------------------------------------------------------------
# Async suffix mandatory — re-enabled after rework (2026-06-15).
# Was previously set to `none` citing "cascading from Dependency changes"
# — the cascade was bogus; rule is core to async conventions.
dotnet_diagnostic.VSTHRD200.severity = error

# No .Result / .Wait() / .GetAwaiter().GetResult() (VSTHRD002 / VSTHRD103)
# and no `async void` (VSTHRD104). Enabled as error 2026-06-16 — the prior
# `none` (citing IStartupFilter.Configure() / MemoryPackSerializer) was
# upstream copy-paste; neither exists in console.x, and a sweep of src +
# tests found 0 violations. See .planning/BACKEND-ISSUES.md.
dotnet_diagnostic.VSTHRD002.severity = error
dotnet_diagnostic.VSTHRD103.severity = error
dotnet_diagnostic.VSTHRD104.severity = error

# Observe awaited result
dotnet_diagnostic.VSTHRD110.severity = warning

# ConfigureAwait — для library code; в app можно отключить
dotnet_diagnostic.MA0004.severity = none

#---------------------------------------------------------------------
# Section 2: sealed по умолчанию
#---------------------------------------------------------------------
dotnet_diagnostic.CA1852.severity = warning # seal internal types

#---------------------------------------------------------------------
# Section 12: Structured logging
#---------------------------------------------------------------------
dotnet_diagnostic.CA2254.severity = error # template should be static expression
dotnet_diagnostic.CA1727.severity = warning # PascalCase placeholders
dotnet_diagnostic.CA1848.severity = none # LoggerMessage source-gen (не обязательно)

#---------------------------------------------------------------------
# Section 1: Naming
#---------------------------------------------------------------------
# Стиль: camelCase без префикса
dotnet_naming_style.camel_case.capitalization = camel_case

# Private/protected/internal fields — camelCase без _
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibility = private, protected, internal, private_protected
dotnet_naming_symbols.private_fields.required_modifiers =

dotnet_naming_rule.private_fields_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_camel_case.style = camel_case
dotnet_naming_rule.private_fields_camel_case.severity = error

# Interfaces — I prefix
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibility = *

dotnet_naming_style.i_prefix.required_prefix = I
dotnet_naming_style.i_prefix.capitalization = pascal_case

dotnet_naming_rule.interfaces_must_start_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_must_start_with_i.style = i_prefix
dotnet_naming_rule.interfaces_must_start_with_i.severity = error

# Async methods — Async suffix
dotnet_naming_symbols.async_methods.applicable_kinds = method
dotnet_naming_symbols.async_methods.applicable_accessibility = *
dotnet_naming_symbols.async_methods.required_modifiers = async

dotnet_naming_style.async_suffix.required_suffix = Async
dotnet_naming_style.async_suffix.capitalization = pascal_case

dotnet_naming_rule.async_methods_end_with_async.symbols = async_methods
dotnet_naming_rule.async_methods_end_with_async.style = async_suffix
dotnet_naming_rule.async_methods_end_with_async.severity = error

# Public members — PascalCase
dotnet_naming_symbols.public_members.applicable_kinds = property, method, field, event, namespace, class, struct, interface, enum, delegate
dotnet_naming_symbols.public_members.applicable_accessibility = public

dotnet_naming_style.pascal.capitalization = pascal_case

dotnet_naming_rule.public_members_pascal.symbols = public_members
dotnet_naming_rule.public_members_pascal.style = pascal
dotnet_naming_rule.public_members_pascal.severity = error

# Constants — PascalCase
dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.applicable_accessibility = *
dotnet_naming_symbols.constants.required_modifiers = const

dotnet_naming_rule.constants_pascal.symbols = constants
dotnet_naming_rule.constants_pascal.style = pascal
dotnet_naming_rule.constants_pascal.severity = error

#---------------------------------------------------------------------
# Section 3: Primary constructors — поощряем
#---------------------------------------------------------------------
csharp_style_prefer_primary_constructors = true : suggestion

#---------------------------------------------------------------------
# Modifier order — Microsoft default (ERROR)
#---------------------------------------------------------------------
csharp_preferred_modifier_order = public, private, protected, internal, file, static, extern, new, virtual, abstract, sealed, override, readonly, unsafe, required, volatile, async : error
dotnet_diagnostic.IDE0036.severity = error

#---------------------------------------------------------------------
# Accessibility modifiers — always (ERROR, включая интерфейсы)
#---------------------------------------------------------------------
dotnet_style_require_accessibility_modifiers = always : error
dotnet_diagnostic.IDE0040.severity = error

#---------------------------------------------------------------------
# Expression-bodied members
#---------------------------------------------------------------------
csharp_style_expression_bodied_methods = false : error # methods must use block body { } — see CODING-RULES §9
csharp_style_expression_bodied_constructors = false : silent
csharp_style_expression_bodied_operators = when_on_single_line : silent
csharp_style_expression_bodied_properties = true : silent
csharp_style_expression_bodied_indexers = true : silent
csharp_style_expression_bodied_accessors = true : silent
csharp_style_expression_bodied_lambdas = true : silent
csharp_style_expression_bodied_local_functions = when_on_single_line : silent

# Using
csharp_prefer_simple_using_statement = true : warning
csharp_style_prefer_method_group_conversion = true : silent
csharp_style_prefer_top_level_statements = true : silent

# UTF-8 string literals (.NET 7+)
csharp_style_prefer_utf8_string_literals = true : warning

# this. qualification — НЕ требуется
dotnet_style_qualification_for_field = false : warning
dotnet_style_qualification_for_property = false : warning
dotnet_style_qualification_for_method = false : warning
dotnet_style_qualification_for_event = false : warning

# Predefined types (int vs Int32)
dotnet_style_predefined_type_for_locals_parameters_members = true : warning
dotnet_style_predefined_type_for_member_access = true : warning

# Parentheses
dotnet_style_parentheses_in_arithmetic_binary_operators = never_if_unnecessary : warning
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity : warning
dotnet_style_parentheses_in_relational_binary_operators = never_if_unnecessary : warning
dotnet_diagnostic.IDE0048.severity = none # add parens for clarity — noise, owner-disabled 2026-06-29

# Object initializers — новая строка
csharp_new_line_before_members_in_object_initializers = false

#---------------------------------------------------------------------
# Roslynator — упрощение кода и минимальность
#---------------------------------------------------------------------
dotnet_diagnostic.RCS1124.severity = warning # inline local variable
dotnet_diagnostic.RCS1173.severity = warning # simplify if-else to ternary
dotnet_diagnostic.RCS1206.severity = warning # conditional access vs if
dotnet_diagnostic.RCS1218.severity = warning # simplify code branching
dotnet_diagnostic.RCS1238.severity = warning # avoid nested ternary

#---------------------------------------------------------------------
# Meziantou — дополнительные best practices
#---------------------------------------------------------------------
dotnet_diagnostic.MA0006.severity = warning # use String.Equals with StringComparison
dotnet_diagnostic.MA0011.severity = warning # IFormatProvider missing
dotnet_diagnostic.MA0016.severity = warning # prefer returning collection abstraction
dotnet_diagnostic.MA0040.severity = warning # forward CancellationToken
dotnet_diagnostic.MA0080.severity = warning # use a cancellation token
dotnet_diagnostic.MA0099.severity = warning # use Explicit enum value
dotnet_diagnostic.MA0110.severity = none # use Regex source generator — owner-disabled: dotnet format переписывает `static readonly Regex` на `partial Regex` property и ломает build (CS9248/CS9249). Класс не partial, генератор не может подсунуть implementation. OK to keep inline Regex для утилитарных парсеров.
dotnet_diagnostic.MA0179.severity = none # use Attribute.IsDefined instead of GetCustomAttribute — owner-disabled 2026-07-02: false positive когда нужно значение атрибута (attr.Alias, attr.AllowedOps). IsDefined возвращает bool, не значение. Конфликтует с VerifyAntiPatternsOnBuild (требует inline `is not { } attr`). См. .planning/BACKEND-ISSUES.md.

#---------------------------------------------------------------------
# Microsoft.CodeAnalysis.NetAnalyzers (CA rules)
#---------------------------------------------------------------------
dotnet_diagnostic.CA1305.severity = warning # specify IFormatProvider
dotnet_diagnostic.CA1720.severity = warning # identifier contains type name — moved from `none` (rework 2026-06-15)
dotnet_diagnostic.CA1822.severity = warning # mark members as static
dotnet_diagnostic.CA1860.severity = warning # avoid using Enumerable.Any() — use .Count != 0
dotnet_diagnostic.CA1862.severity = warning # use StringComparison method overloads
dotnet_diagnostic.CA2008.severity = warning # do not create tasks without TaskScheduler

# NEW (added 2026-06-15 rework) — for build-time visibility
dotnet_diagnostic.CA1002.severity = warning # don't expose generic lists — enforce IReadOnlyCollection<T> in public API
dotnet_diagnostic.CA1052.severity = warning # static holder types should be Static or NotInheritable
dotnet_diagnostic.CA2016.severity = warning # forward CancellationToken — BCL variant, complements MA0040

#---------------------------------------------------------------------
# Project-specific OFF — `severity = none` with documented justification
#---------------------------------------------------------------------
# Group A: real analyzer false positives (analyzer bug or limitation).
dotnet_diagnostic.IDE0001.severity = none # simplify name — false positive on (ICommand<Unit>) cast and IOptions<>
dotnet_diagnostic.IDE0058.severity = none # expression value never used — false positive on `using var x = ...`
dotnet_diagnostic.MA0003.severity = none # name the parameter — argument-name hints are a style preference
dotnet_diagnostic.MA0007.severity = none # trailing comma in collection initializer — noise, owner-disabled 2026-06-29
dotnet_diagnostic.MA0038.severity = none # make method static — false positive on primary-ctor methods
dotnet_diagnostic.MA0154.severity = none # use langword in XML — false positive on 'try' (not in langword list)
dotnet_diagnostic.RCS1208.severity = none # reduce 'if' nesting — logger.IsEnabled wrappers and foreach+if patterns are common
dotnet_diagnostic.RCS1228.severity = none # unused param element — delegate callbacks with unused params
dotnet_diagnostic.RCS1247.severity = none # fix doc tag — multiline <c> tag is fine
dotnet_diagnostic.MA0136.severity = none # raw string contains implicit EOL — multi-line raw SQL/log templates are intentional
dotnet_diagnostic.MA0101.severity = none # string contains non-deterministic EOL — same family as MA0136, raw strings with newlines

# Group B: project-specific divergences from analyzer defaults.
dotnet_diagnostic.CA1031.severity = none # do not catch general exception types — иногда оправдано
dotnet_diagnostic.CA1062.severity = none # validate arguments — слишком шумно с required
dotnet_diagnostic.CA1303.severity = none # localize strings — не нужно
dotnet_diagnostic.CA1707.severity = none # identifier should not contain underscore — see tests/ override below
dotnet_diagnostic.CA1716.severity = none # identifier should not match keyword
dotnet_diagnostic.CA1812.severity = none # avoid uninstantiated internal classes (DI)
dotnet_diagnostic.CA1873.severity = none # wrap logger.LogX in IsEnabled — IsEnabled wrappers are noise
dotnet_diagnostic.CA2007.severity = none # ConfigureAwait — не нужно в app code (dup of MA0004)
dotnet_diagnostic.MA0042.severity = none # do not use blocking calls in async — sync Validate() in preloaders is fine
dotnet_diagnostic.MA0045.severity = none # make method async — sync filter/extension methods intentionally sync
dotnet_diagnostic.MA0048.severity = none # file name must match type name — cascading from Dependency file splits
dotnet_diagnostic.MA0051.severity = none # method too long (>60 lines) — exchange subscribers are intrinsically long
# VSTHRD002 / VSTHRD103 moved to §6 (Async / await) as `error` — 2026-06-16.

#---------------------------------------------------------------------
# Documented trade-off (cannot satisfy both in .NET 8+):
#   - RCS1194 (Roslynator): "Implement exception constructors" — wants
#     protected (SerializationInfo, StreamingContext) ctor on every
#     exception class.
#   - SYSLIB0051 (BCL): Exception(SerializationInfo, StreamingContext)
#     is OBSOLETE in .NET 8+ ("obsolete formatter-based serialization").
# These two rules directly conflict — adding the ctor to satisfy RCS1194
# triggers SYSLIB0051 (which becomes an error under
# TreatWarningsAsErrors=true). Resolution: set RCS1194 to none (rule
# stays inactive in IDE). See .planning/BACKEND-ISSUES.md (2026-06-11).
#---------------------------------------------------------------------
dotnet_diagnostic.RCS1194.severity = none # SYSLIB0051 conflict; see .planning/BACKEND-ISSUES.md

# =====================================================================
# ReSharper / Rider properties
# =====================================================================
# ReSharper/Rider reads these from .editorconfig. Other IDEs (VS without
# the ReSharper extension, VSCode with the C# extension) silently ignore
# unknown properties — no effect, no warning. DO NOT move to a sibling
# file (e.g. .editorconfig.resharper): Rider reads .editorconfig only,
# not siblings. For machine-local overrides, use Rider's settings layer
# (Settings → Editor → Code Style → C#).
[*.cs]
resharper_align_multiline_parameter = true
resharper_align_ternary = none
resharper_autodetect_indent_settings = true
resharper_blank_lines_after_control_transfer_statements = 1
resharper_blank_lines_after_multiline_statements = 1
resharper_blank_lines_before_block_statements = 1
resharper_braces_for_for = required
resharper_braces_for_foreach = required
resharper_braces_for_ifelse = required
resharper_braces_for_while = required
resharper_braces_redundant = false
resharper_csharp_blank_lines_around_single_line_invocable = 1
resharper_csharp_continuous_indent_multiplier = 2
resharper_csharp_empty_block_style = together_same_line
resharper_csharp_keep_blank_lines_in_code = 1
resharper_csharp_max_line_length = 179
resharper_csharp_wrap_arguments_style = chop_if_long
resharper_csharp_wrap_parameters_style = chop_if_long
resharper_formatter_off_tag = @formatter:off
resharper_formatter_on_tag = @formatter : on
resharper_formatter_tags_enabled = true
resharper_indent_nested_fixed_stmt = true
resharper_indent_nested_foreach_stmt = true
resharper_indent_nested_for_stmt = true
resharper_indent_nested_lock_stmt = true
resharper_indent_nested_usings_stmt = true
resharper_indent_nested_while_stmt = true
resharper_keep_existing_attribute_arrangement = true
resharper_keep_existing_embedded_block_arrangement = true
resharper_max_attribute_length_for_same_line = 80
resharper_max_formal_parameters_on_line = 1000
resharper_max_invocation_arguments_on_line = 6
resharper_new_line_before_while = true
resharper_outdent_statement_labels = true
resharper_parentheses_redundancy_style = remove
resharper_place_accessorholder_attribute_on_same_line = false
resharper_place_accessor_attribute_on_same_line = false
resharper_place_expr_property_on_single_line = true
resharper_place_field_attribute_on_same_line = if_owner_is_single_line
resharper_place_simple_anonymousmethod_on_single_line = false
resharper_place_simple_embedded_statement_on_same_line = false
resharper_place_simple_initializer_on_single_line = false
resharper_place_simple_list_pattern_on_single_line = false
resharper_show_autodetect_configure_formatting_tip = false
resharper_use_continuous_indent_inside_initializer_braces = false
resharper_use_continuous_indent_inside_parens = false
resharper_use_indent_from_vs = false
resharper_wrap_after_primary_constructor_declaration_lpar = false
resharper_wrap_list_pattern = chop_if_long
resharper_wrap_object_and_collection_initializer_style = chop_always
resharper_xmldoc_linebreak_before_elements = summary, response, remarks, example, returns, param, typeparam, value, para

# ReSharper inspection severities
resharper_arrange_redundant_parentheses_highlighting = hint
resharper_arrange_this_qualifier_highlighting = hint
resharper_arrange_type_member_modifiers_highlighting = hint
resharper_arrange_type_modifiers_highlighting = hint
resharper_built_in_type_reference_style_for_member_access_highlighting = hint
resharper_built_in_type_reference_style_highlighting = hint
resharper_class_never_instantiated_global_highlighting = none
resharper_class_never_instantiated_local_highlighting = none
resharper_convert_to_using_declaration_highlighting = hint
resharper_explicit_caller_info_argument_highlighting = none
resharper_inconsistent_naming_highlighting = hint
resharper_invalid_xml_doc_comment_highlighting = hint
resharper_member_can_be_private_global_highlighting = none
resharper_member_can_be_private_local_highlighting = none
resharper_method_has_async_overload_with_cancellation_highlighting = hint
resharper_mvc_action_not_resolved_highlighting = warning
resharper_mvc_area_not_resolved_highlighting = warning
resharper_mvc_controller_not_resolved_highlighting = warning
resharper_redundant_base_qualifier_highlighting = warning
resharper_suggest_var_or_type_built_in_types_highlighting = hint
resharper_suggest_var_or_type_elsewhere_highlighting = hint
resharper_suggest_var_or_type_simple_types_highlighting = hint
resharper_unused_auto_property_accessor_global_highlighting = hint
resharper_unused_auto_property_accessor_local_highlighting = hint
resharper_unused_method_return_value_global_highlighting = none
resharper_unused_method_return_value_local_highlighting = none

# =====================================================================
# Per-glob overrides
# =====================================================================

# --- EF Core migrations ---
# Generated by `dotnet ef migrations add`. Re-formatting creates noisy diffs
# every regeneration; the IDE0058 / MA0197 warnings come from the EF Core
# fluent builder pattern. We don't hand-edit migrations.
[**/Migrations/**]
charset = utf-8-bom
# EF Core migrations are auto-generated design-time artifacts. Any hand-edit (even a
# trailing comma) is overwritten on the next `migrations add`, so style enforcement
# here is pure noise. Disable the rules that fire on generated code; see
# process/build-verification.md. (generated_code = true does NOT work for hand-placed
# files — `dotnet format` still walks them — so we list the rules explicitly.)
#
# Core IDE codestyle — irrelevant to generated fluent builders.
dotnet_diagnostic.IDE0161.severity = none # file-scoped namespace (gen: uses proper)
dotnet_diagnostic.IDE1006.severity = none # naming style (gen: lowerCase helpers)
dotnet_diagnostic.IDE0058.severity = none # unused expression value (gen: fluent chain)
dotnet_diagnostic.IDE0007.severity = none # var vs explicit type (gen: long generic names)
dotnet_diagnostic.IDE0008.severity = none # explicit type vs var (gen: inverse)
dotnet_diagnostic.IDE0040.severity = none # access modifiers (gen: missing on interface)
dotnet_diagnostic.IDE0047.severity = none # redundant parens (gen: explicit grouping)
dotnet_diagnostic.IDE0078.severity = none # use pattern matching (gen: prefers is-null)
dotnet_diagnostic.IDE0290.severity = none # use primary constructor (gen: explicit ctor)
dotnet_diagnostic.IDE0022.severity = none # expression-bodied method (gen: block body)
dotnet_diagnostic.IDE0021.severity = none # expression-bodied constructor (gen: block)
dotnet_diagnostic.IDE0060.severity = none # unused parameter (gen: required by override)
# MA / CA / RCS — analyzer noise on generated code.
dotnet_diagnostic.MA0197.severity = none # unused private member (gen: fluent tmp vars)
dotnet_diagnostic.CA1861.severity = none # constant array allocation (gen: every time)
dotnet_diagnostic.CA1305.severity = none # locale-specific string op (gen: SQL string keys)
dotnet_diagnostic.CA1822.severity = none # make member static (gen: instance pattern)
dotnet_diagnostic.RCS1036.severity = none # unnecessary blank line (gen: fluent formatting)
dotnet_diagnostic.RCS1037.severity = none # trailing whitespace (gen: CRLF artifacts)
dotnet_diagnostic.RCS1038.severity = none # file header copyright (gen: no copyright)
dotnet_diagnostic.RCS1141.severity = none # add 'param' element (gen: trivial types)
charset = unset

[**/Migrations/*.cs]
charset = utf-8-bom
# Legacy glob for projects that keep migrations directly in Migrations/ (no
# per-module subfolder). Mirrors the suppressed rules in [**/Migrations/**]
# above so both layouts compile clean.
dotnet_diagnostic.IDE0161.severity = none
dotnet_diagnostic.IDE1006.severity = none
dotnet_diagnostic.IDE0058.severity = none
dotnet_diagnostic.IDE0007.severity = none
dotnet_diagnostic.IDE0008.severity = none
dotnet_diagnostic.IDE0040.severity = none
dotnet_diagnostic.IDE0047.severity = none
dotnet_diagnostic.IDE0078.severity = none
dotnet_diagnostic.IDE0290.severity = none
dotnet_diagnostic.IDE0022.severity = none
dotnet_diagnostic.IDE0021.severity = none
dotnet_diagnostic.IDE0060.severity = none
dotnet_diagnostic.MA0197.severity = none
dotnet_diagnostic.CA1861.severity = none
dotnet_diagnostic.CA1305.severity = none
dotnet_diagnostic.CA1822.severity = none
dotnet_diagnostic.RCS1141.severity = none
charset = unset

# --- NamespaceMarker ---
# Empty braced class bodies for NetArchTest; the `class Foo;` shorthand
# (RCS1251) would hide intent in a project that already has many empty
# body files.
[**/_NamespaceMarker.cs]
dotnet_diagnostic.RCS1251.severity = none
dotnet_diagnostic.MA0182.severity = none

# --- Tests ---
# Test-only relaxations now live in tests/.editorconfig (a non-root
# .editorconfig layered on top of this file). This root file stays the
# law for production code. Dev/test controllers that live UNDER src/
# (not in the tests/ tree) are still handled by [*Test*Controller.cs] below.

# --- Test Controllers ---
# Dev/test-only controllers live in the production Application assembly
# but are gated by #if DEBUG, marked [ApiExplorerSettings(IgnoreApi = true)],
# and routed under /api/v1/test/*. Same rationale as the tests/ block.
[*Test*Controller.cs]
dotnet_diagnostic.RCS1141.severity = none
dotnet_diagnostic.RCS1142.severity = none
dotnet_diagnostic.RCS1140.severity = none
dotnet_diagnostic.IDE0370.severity = none

# --- BannerArt ---
# BannerArt is a string-rendering library; const char vs const string
# isn't a meaningful distinction (Box/Icon are documented as strings),
# and `sb.Append(Box.TopLeft)` with `Box.TopLeft` as const string is
# idiomatic for the call sites. CA1834 (prefer char overload) doesn't
# apply — perf cost is negligible for art rendering and the rule
# cascades into CA1305/CS0029 conflicts.
[src/shared/Plexor.Shared.Console/BannerArt.cs]
dotnet_diagnostic.CA1834.severity = none
